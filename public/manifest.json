{
  "manifest_version": 3,
  "name": "Bookmark Visualizer",
  "version": "0.1.0",
  "description": "A Chrome and Edge bookmark workspace for visual browsing and searching native bookmarks.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Bookmark Visualizer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "commands": {
    "open-quick-save": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save the current page to Bookmark Visualizer"
    }
  },
  "permissions": ["bookmarks", "storage", "activeTab", "scripting", "tabs"]
}
