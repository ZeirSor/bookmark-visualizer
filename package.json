{
  "name": "bookmark-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run --dir src --exclude '**/node_modules/**' --exclude '**/.git/**'",
    "docs:check": "node scripts/check-doc-paths.mjs",
    "verify:quick-save-shortcut": "node scripts/verify-quick-save-shortcut.mjs",
    "verify:popup-entry": "node scripts/verify-quick-save-shortcut.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.320",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
